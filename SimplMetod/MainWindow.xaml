<Window x:Class="SimplMetod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Симплекс-метод — двухфазный" 
        Height="750" 
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Левая панель — Параметры -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,15,15">

            <StackPanel>
                <TextBlock Text="Параметры задачи" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Количество переменных"/>
                <TextBox x:Name="TxtNumVariables" Text="3" Margin="0,4"/>

                <TextBlock Text="Количество ограничений"/>
                <TextBox x:Name="TxtNumConstraints" Text="3" Margin="0,4"/>

                <TextBlock Text="Тип оптимизации"/>
                <ComboBox x:Name="CbOptimize" Margin="0,8,0,12">
                    <ComboBoxItem Content="Максимизировать" IsSelected="True"/>
                    <ComboBoxItem Content="Минимизировать"/>
                </ComboBox>

                <Button Content="Обновить"
                        Click="UpdateInterface_Click"
                        Background="#3498DB" Foreground="White" Height="36"/>

                <Button Content="Рассчитать"
                        Click="Solve_Click"
                        Background="#2ECC71" Foreground="White"
                        FontWeight="Bold" Height="36" Margin="0,8,0,0"/>

                <Button Content="Очистить всё"
                        Click="ClearAll_Click"
                        Background="#E74C3C" Foreground="White" Height="36" Margin="0,8,0,0"/>

                <!-- === БЛОК РАБОТЫ С ФАЙЛАМИ === -->
                <GroupBox Header="Работа с файлами" Margin="0,20,0,0">
                    <UniformGrid Rows="2" Margin="10">
                        <Button Content="Загрузить из файла" 
                                Click="BtnLoadFromFile_Click"
                                Background="#95A5A6" Foreground="White"/>
                        <Button Content="Сохранить решение" 
                                Click="BtnSaveResult_Click"
                                Background="#95A5A6" Foreground="White"/>
                    </UniformGrid>
                </GroupBox>
            </StackPanel>
        </Border>

        <!-- Правая часть — Целевая функция и ограничения -->
        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
            <!-- Целевая функция -->
            <Border Background="White" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Целевая функция" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" x:Name="TargetFunctionPanel"/>
                </StackPanel>
            </Border>

            <!-- Ограничения -->
            <Border Background="White" CornerRadius="10" Padding="12">
                <DockPanel>
                    <TextBlock Text="Ограничения" 
                               FontWeight="Bold" 
                               DockPanel.Dock="Top" 
                               Margin="0,0,0,8"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Height="220">
                        <StackPanel x:Name="ConstraintsPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- Результат -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                Background="White"
                CornerRadius="10"
                Padding="15">
            <DockPanel>
                <TextBlock Text="Результат решения"
                           FontWeight="Bold"
                           FontSize="15"
                           DockPanel.Dock="Top"
                           Margin="0,0,0,10"/>
                <TextBox x:Name="TxtResult"
                         FontFamily="Consolas"
                         FontSize="13"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         IsReadOnly="True"
                         Background="#FAFAFA"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>